# WhatsApp Bridge Configuration
WHATSAPP_ENABLED=true

# WhatsApp group JID (e.g. 120363XXXXXXXXXX@g.us)
WHATSAPP_GROUP_JID=

# Encryption key for auth state (32 bytes hex, generate with: openssl rand -hex 32)
WHATSAPP_AUTH_ENCRYPTION_KEY=

# Mattermost connection
MATTERMOST_URL=https://mm.qureshi.io
MATTERMOST_TOKEN=
MATTERMOST_TEAM_NAME=qureshi

# Slapshare channel ID
SLAPSHARE_CHANNEL_ID=o18rtx6ewifc8r1dnc3kp4xoic

# Bot username (to ignore own messages)
BOT_USERNAME=slaptastic

# Database path (relative to working directory)
DATABASE_PATH=./data/whatsapp-bridge.db

# Auth state storage path
AUTH_STATE_PATH=./data/auth-state

# Log level: debug, info, warn, error
LOG_LEVEL=info
