# Slaptastic Music Library Configuration

# Application
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=info

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/slaptastic.db

# Music storage
MUSIC_DIR=/app/music
MUSIC_FORMAT=opus
MUSIC_QUALITY=320

# Download settings
DOWNLOAD_CONCURRENCY=3
DOWNLOAD_TIMEOUT=300

# yt-dlp configuration
YTDLP_COOKIES_FILE=
YTDLP_PROXY=

# Jellyfin integration (optional)
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

# Mattermost notifications (optional)
MATTERMOST_WEBHOOK_URL=
MATTERMOST_CHANNEL=music-imports

# Security
SECRET_KEY=change-me-to-a-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_PER_MINUTE=60
